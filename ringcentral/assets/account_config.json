      }
    },
    {
      "key": "get_audit_logs",
      "label": "Audit logs",
      "editable": true,
      "checkbox": {
        "default": true
      }
    },
    {
      "key": "get_analytics_metrics",
      "label": "Analytics metrics",
      "editable": true,
      "checkbox": {
        "default": true
      }
    },
    {
      "key": "get_message_metrics",
      "label": "SMS metrics",
