{
  "supported_auth_methods": [
    {
      "auth_name": "oauth",
      "oauth2_authorization_code": {
        "authorization_server": {
          "authorization_endpoint": "https://platform.ringcentral.com/restapi/oauth/authorize"
        },
        "authorization_request": {
          "scopes": [
            "ReadAccounts",
            "ReadCallLog",
            "ReadContacts",
            "ReadMessages",
            "ReadPresence"
          ],
          "pkce": "required"
        }
      }
    }
  ],
