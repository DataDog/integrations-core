## All options defined here are available to all instances.
#
init_config:

    ## @param global_custom_queries - list of mappings - optional
    ## See `custom_queries` defined below.
    ##
    ## Global custom queries can be applied to all instances using the
    ## `use_global_custom_queries` setting at the instance level.
    #
    # global_custom_queries:
    #   - metric_prefix: ibm_db2
    #     query: <QUERY>
    #     columns: <COLUMNS>
    #     tags: <TAGS>

    ## @param service - string - optional
    ## Attach the tag `service:<SERVICE>` to every metric, event, and service check emitted by this integration.
    ##
    ## Additionally, this sets the default `service` for every log source.
    #
    # service: <SERVICE>

## Every instance is scheduled independently of the others.
#
instances:

  -
    ## @param dbm - boolean - optional - default: false
    ## Set to `true` to enable Database Monitoring.
    #
    # dbm: false

    ## @param db - string - required
    ## The name of the database to establish a connection with.
    #
    db: <DATABASE_NAME>

    ## @param username - string - required
    ## The database user to authenticate as.
    #
    username: <USERNAME>

    ## @param password - string - required
    ## The password of `username`.
    #
    password: <PASSWORD>

    ## @param host - string - optional
    ## The hostname used to connect to a remote or uncataloged database.
    #
    # host: <HOSTNAME>

    ## @param port - integer - optional - default: 50000
    ## The port used to connect to a remote or uncataloged database.
    #
    # port: 50000

    ## @param security - string - optional - default: none
    ## Set this parameter to `ssl` to use the SSL protocol for a connection to the database server using the default
    ## certificate from the ibm-db driver package. Specifying `tls_cert` is not required when using this option.
    #
    # security: none

    ## @param tls_cert - string - optional
    ## The path to a SSL certificate to use, when connecting to a database in a secure fashion. It
    ## has to be accessible and readable by the agent user.
    #
    # tls_cert: <TLS_CERT>

    ## @param connection_timeout - integer - optional - default: 10
    ## Connection timeout in seconds
    #
    # connection_timeout: 10

    ## @param collect_container_metrics - boolean - optional - default: false
    ## Collect per-container table space metrics from `MON_GET_CONTAINER`. These metrics can create one series per
    ## table space container and member.
    #
    # collect_container_metrics: false

    ## @param collect_table_metrics - boolean - optional - default: false
    ## Collect per-table metrics from `MON_GET_TABLE`. These metrics can create one series per table, partition,
    ## and member, so collection is disabled by default.
    #
    # collect_table_metrics: false

    ## @param table_metrics_limit - integer - optional - default: 300
    ## Maximum number of tables to collect metrics for when `collect_table_metrics` is enabled.
    #
    # table_metrics_limit: 300

    ## @param collect_index_metrics - boolean - optional - default: false
    ## Collect per-index metrics from `MON_GET_INDEX`. These metrics can create one series per index, partition,
    ## and member, so collection is disabled by default.
    #
    # collect_index_metrics: false

    ## @param index_metrics_limit - integer - optional - default: 1000
    ## Maximum number of indexes to collect metrics for when `collect_index_metrics` is enabled.
    #
    # index_metrics_limit: 1000

    ## @param collect_connection_metrics - boolean - optional - default: false
    ## Collect per-connection metrics from `MON_GET_CONNECTION`. These metrics can create one series per active
    ## connection, so collection is disabled by default.
    #
    # collect_connection_metrics: false

    ## @param connection_metrics_limit - integer - optional - default: 300
    ## Maximum number of connections to collect metrics for when `collect_connection_metrics` is enabled.
    #
    # connection_metrics_limit: 300

    ## @param collect_fcm_metrics - boolean - optional - default: false
    ## Collect pureScale Fast Communication Manager metrics. These metrics are only emitted on clustered Db2
    ## instances and are disabled by default.
    #
    # collect_fcm_metrics: false

    ## @param collect_fcm_connection_metrics - boolean - optional - default: false
    ## Collect per-connection pureScale Fast Communication Manager metrics. These metrics can create one series per
    ## FCM connection and member, so collection is disabled by default.
    #
    # collect_fcm_connection_metrics: false

    ## @param collect_cf_metrics - boolean - optional - default: false
    ## Collect pureScale cluster caching facility metrics. These metrics are only emitted on clustered Db2 instances
    ## and are disabled by default.
    #
    # collect_cf_metrics: false

    ## @param collect_group_bufferpool_metrics - boolean - optional - default: false
    ## Collect pureScale group buffer pool metrics. These metrics are only emitted on clustered Db2 instances and
    ## are disabled by default.
    #
    # collect_group_bufferpool_metrics: false

    ## @param collect_wlm_service_class_metrics - boolean - optional - default: false
    ## Collect Workload Manager metrics by service superclass and subclass. Workload-level WLM metrics are always
    ## collected; enable this option only when service-class attribution is needed.
    #
    # collect_wlm_service_class_metrics: false

    ## @param reported_hostname - string - optional
    ## Set the reported hostname for this instance. This value overrides the hostname detected by the Agent
    ## and can be useful to set a custom hostname when connecting to a remote database through a proxy.
    #
    # reported_hostname: <REPORTED_HOSTNAME>

    ## @param exclude_hostname - boolean - optional - default: false
    ## Omit the hostname from tags and events. This is useful when the database host is not monitored by an agent.
    #
    # exclude_hostname: false

    ## Controls how the database is identified. Each unique value of this identifier appears in DBM as a separate
    ## billable instance.
    ##
    ## The default value is the resolved hostname for the instance, which respects the `reported_hostname` option.
    ##
    ## This value is used as-is for the display name of the instance but is normalized when applied as the
    ## `database_instance` tag. See https://docs.datadoghq.com/getting_started/tagging/ for more details on
    ## Datadog tag normalization.
    #
    # database_identifier:

        ## @param template - string - optional - default: $resolved_hostname
        ## The template to use for the database identifier. The default value is `$resolved_hostname`.
        ## You can use the following variables, prefixed by `$` in the template:
        ## - resolved_hostname: The resolved hostname of the instance, which respects the `reported_hostname` option.
        ## - host: The provided host of the instance.
        ## - port: The port number of the instance.
        ## - db: The configured Db2 database name.
        #
        # template: $resolved_hostname:$db

    ## Configure collection of DBM query metrics.
    #
    # query_metrics:

        ## @param enabled - boolean - optional - default: true
        ## Enable collection of query metrics. Requires `dbm: true`.
        #
        # enabled: true

        ## @param collection_interval - number - optional - default: 10
        ## Set the query metric collection interval (in seconds). Each collection reads
        ## `MON_GET_PKG_CACHE_STMT` and computes interval deltas client-side.
        #
        # collection_interval: 10

    ## Configure DBM query sample execution plan collection.
    #
    # query_samples:

        ## @param enabled - boolean - optional - default: false
        ## Enable collection of execution plans from Db2 EXPLAIN tables. Requires `dbm: true`.
        #
        # enabled: false

        ## @param collection_interval - number - optional - default: 10
        ## Set the query sample collection interval (in seconds). This interval is used when query metrics are
        ## disabled and query samples are enabled.
        #
        # collection_interval: 10

        ## @param explain_schema - string - optional - default: <MONITORING_USER>
        ## Set the schema where the integration creates and reads Db2 EXPLAIN tables. The default is the
        ## configured monitoring user's schema.
        #
        # explain_schema: DATADOG

    ## Configure DBM query activity collection.
    #
    # query_activity:

        ## @param enabled - boolean - optional - default: true
        ## Enable collection of in-flight query activity from `MON_GET_ACTIVITY`. Requires `dbm: true`.
        #
        # enabled: true

        ## @param collection_interval - number - optional - default: 10
        ## Set the query activity collection interval (in seconds). This is an ASH-style snapshot of currently
        ## running statements, not a complete query log.
        #
        # collection_interval: 10

    ## Configure collection of database manager and database settings.
    #
    # collect_settings:

        ## @param enabled - boolean - optional - default: true
        ## Enable collection of database manager and database settings. Requires `dbm: true`.
        #
        # enabled: true

        ## @param collection_interval - number - optional - default: 600
        ## Set the settings collection interval (in seconds). Each collection queries `SYSIBMADM.DBMCFG` and
        ## `SYSIBMADM.DBCFG`.
        #
        # collection_interval: 600

        ## @param ignored_settings_patterns - list of strings - optional
        ## A list of setting patterns to ignore. Any setting key matching one of the values in this list will not
        ## be collected. This uses the Db2 `LIKE` pattern-matching approach.
        #
        # ignored_settings_patterns:
        #   - diag%

    ## Configure collection of database schema metadata.
    #
    # collect_schemas:

        ## @param enabled - boolean - optional - default: false
        ## Enable collection of database schema metadata from `SYSCAT` catalog views. Requires `dbm: true`.
        #
        # enabled: false

        ## @param collection_interval - number - optional - default: 600
        ## Set the database schema collection interval (in seconds).
        #
        # collection_interval: 600

        ## @param max_tables - integer - optional - default: 300
        ## Set the maximum number of tables to collect.
        #
        # max_tables: 300

        ## @param max_columns - integer - optional - default: 50
        ## Set the maximum number of columns to collect per table.
        #
        # max_columns: 50

        ## @param max_query_duration - number - optional - default: 60
        ## Set the maximum time for schema collection queries (in seconds).
        #
        # max_query_duration: 60

        ## @param include_schemas - list of strings - optional
        ## Include only schemas matching one of these Db2 `LIKE` patterns.
        #
        # include_schemas:
        #   - APP%

        ## @param exclude_schemas - list of strings - optional
        ## Exclude schemas matching one of these Db2 `LIKE` patterns.
        #
        # exclude_schemas:
        #   - TEST%

        ## @param include_tables - list of strings - optional
        ## Include only tables matching one of these Db2 `LIKE` patterns.
        #
        # include_tables:
        #   - ORDERS%

        ## @param exclude_tables - list of strings - optional
        ## Exclude tables matching one of these Db2 `LIKE` patterns.
        #
        # exclude_tables:
        #   - TMP%

    ## This block defines the configuration for AWS RDS Db2 instances.
    ##
    ## Complete this section if you have installed the Datadog AWS Integration
    ## (https://docs.datadoghq.com/integrations/amazon_web_services) to enrich instances
    ## with Db2 integration telemetry.
    ##
    ## These values are only applied when `dbm: true` option is set.
    #
    # aws:

        ## @param instance_endpoint - string - optional
        ## Set to the Endpoint.Address of the instance the agent is connecting to.
        #
        # instance_endpoint: mydb.cfxgae8cilcf.us-east-1.rds.amazonaws.com

        ## @param region - string - optional
        ## Equal to the region of the instance the agent is connecting to.
        #
        # region: us-east-1

    ## This block defines the configuration for Google Cloud SQL instances.
    ##
    ## Complete this section if you have installed the Datadog GCP Integration
    ## (https://docs.datadoghq.com/integrations/google_cloud_platform) to enrich instances
    ## with Db2 integration telemetry.
    ##
    ## These values are only applied when `dbm: true` option is set.
    #
    # gcp:

        ## @param project_id - string - optional
        ## Equal to the GCP resource's project ID.
        #
        # project_id: foo-project

        ## @param instance_id - string - optional
        ## Equal to the GCP resource's instance ID.
        #
        # instance_id: foo-database

    ## This block defines the configuration for Azure Db2 instances.
    ##
    ## Complete this section if you have installed the Datadog Azure Integration
    ## (https://docs.datadoghq.com/integrations/azure) to enrich instances with Db2 integration telemetry.
    ## These values are only applied when `dbm: true` option is set.
    #
    # azure:

        ## @param deployment_type - string - optional
        ## Equal to the deployment type for the managed database.
        #
        # deployment_type: virtual_machine

        ## @param fully_qualified_domain_name - string - optional
        ## Equal to the fully qualified domain name of the Azure Db2 database.
        #
        # fully_qualified_domain_name: db2-database.database.windows.net

    ## Configure how the SQL obfuscator behaves.
    ## Note: This option only applies when `dbm` is enabled.
    #
    # obfuscator_options:

        ## @param obfuscation_mode - string - optional - default: obfuscate_and_normalize
        ## Set the obfuscation mode. The obfuscation mode determines how the SQL obfuscator obfuscates SQL
        ## statements.
        #
        # obfuscation_mode: obfuscate_and_normalize

        ## @param replace_digits - boolean - optional - default: false
        ## Set to `true` to replace digits in identifiers and table names with question marks in SQL statements.
        #
        # replace_digits: false

        ## @param collect_metadata - boolean - optional - default: true
        ## Set to `false` to disable collection of metadata in SQL statements.
        #
        # collect_metadata: true

        ## @param collect_tables - boolean - optional - default: true
        ## Set to `false` to disable collection of tables in SQL statements.
        ## Requires `collect_metadata: true`.
        #
        # collect_tables: true

        ## @param collect_commands - boolean - optional - default: true
        ## Set to `false` to disable collection of commands in SQL statements.
        ## Requires `collect_metadata: true`.
        #
        # collect_commands: true

        ## @param collect_comments - boolean - optional - default: true
        ## Set to `false` to disable collection of comments in SQL statements.
        ## Requires `collect_metadata: true`.
        #
        # collect_comments: true

        ## @param collect_procedures - boolean - optional - default: true
        ## Set to `false` to disable collection of procedures in SQL statements.
        ## Requires `collect_metadata: true`.
        #
        # collect_procedures: true

        ## @param keep_sql_alias - boolean - optional - default: true
        ## Set to `true` to keep SQL aliases in obfuscated SQL statements.
        #
        # keep_sql_alias: true

        ## @param remove_space_between_parentheses - boolean - optional - default: false
        ## Set to `true` to remove spaces between parentheses in normalized SQL statements.
        #
        # remove_space_between_parentheses: false

        ## @param keep_null - boolean - optional - default: false
        ## Set to `true` to keep the keyword `NULL` in obfuscated SQL statements.
        #
        # keep_null: false

        ## @param keep_boolean - boolean - optional - default: false
        ## Set to `true` to keep the keywords `TRUE` and `FALSE` in obfuscated SQL statements.
        #
        # keep_boolean: false

        ## @param keep_positional_parameter - boolean - optional - default: false
        ## Set to `true` to keep positional parameters in obfuscated SQL statements.
        #
        # keep_positional_parameter: false

        ## @param replace_bind_parameter - boolean - optional - default: false
        ## Set to `true` to replace bind parameters in obfuscated SQL statements.
        #
        # replace_bind_parameter: false

        ## @param keep_trailing_semicolon - boolean - optional - default: false
        ## Set to `true` to keep trailing semicolons in normalized SQL statements.
        #
        # keep_trailing_semicolon: false

        ## @param keep_identifier_quotation - boolean - optional - default: false
        ## Set to `true` to keep identifier quotations in normalized SQL statements.
        #
        # keep_identifier_quotation: false

    ## @param only_custom_queries - boolean - optional - default: false
    ## Set this parameter to `true` if you want to skip the integration's default metrics collection.
    ## Only metrics specified in `custom_queries` will be collected.
    #
    # only_custom_queries: false

    ## @param use_global_custom_queries - string - optional - default: true
    ## How `global_custom_queries` should be used for this instance. There are 3 options:
    ##
    ## 1. true - `global_custom_queries` override `custom_queries`.
    ## 2. false - `custom_queries` override `global_custom_queries`.
    ## 3. extend - `global_custom_queries` are used in addition to any `custom_queries`.
    #
    # use_global_custom_queries: 'true'

    ## @param custom_queries - list of mappings - optional
    ## Each query must have 3 fields:
    ##
    ## 1. metric_prefix - This is what each metric will start with.
    ## 2. query - This is the SQL to execute. It can be a simple statement or a multi-line script.
    ## 3. columns - This is a list representing each column, ordered sequentially
    ##              from left to right. The number of columns must equal the number
    ##              of columns returned in the query.
    ##              There are 2 required pieces of data:
    ##                a. name - This is the suffix to append to the metric_prefix
    ##                          in order to form the full metric name. If `type` is
    ##                          `tag`, this column will instead be considered a tag
    ##                          and will be applied to every metric collected by
    ##                          this particular query.
    ##                b. type - This is the submission method (gauge, count, rate, etc.).
    ##                          This can also be set to `tag` to tag each metric in the row
    ##                          with the name and value of the item in this column. You can
    ##                          use the `count` type to perform aggregation for queries that
    ##                          return multiple rows with the same or no tags.
    ##
    ##               Columns without a name are ignored, put this for any column you wish to skip:
    ##                 - {}
    ## 4. tags (optional) - A list of tags to apply to each metric.
    #
    # custom_queries:
    #   - metric_prefix: ibm_db2
    #     query: SELECT files_closed, tbsp_name FROM TABLE(MON_GET_TABLESPACE(NULL, -1))
    #     columns:
    #     - name: tablespace.files_closed
    #       type: monotonic_count
    #     - name: tablespace
    #       type: tag
    #     tags:
    #     - test:ibm_db2

    ## @param tags - list of strings - optional
    ## A list of tags to attach to every metric and service check emitted by this instance.
    ##
    ## Learn more about tagging at https://docs.datadoghq.com/tagging
    #
    # tags:
    #   - <KEY_1>:<VALUE_1>
    #   - <KEY_2>:<VALUE_2>

    ## @param service - string - optional
    ## Attach the tag `service:<SERVICE>` to every metric, event, and service check emitted by this integration.
    ##
    ## Overrides any `service` defined in the `init_config` section.
    #
    # service: <SERVICE>

    ## @param min_collection_interval - number - optional - default: 15
    ## This changes the collection interval of the check. For more information, see:
    ## https://docs.datadoghq.com/developers/write_agent_check/#collection-interval
    #
    # min_collection_interval: 15

    ## @param empty_default_hostname - boolean - optional - default: false
    ## This forces the check to send metrics with no hostname.
    ##
    ## This is useful for cluster-level checks.
    #
    # empty_default_hostname: false

    ## @param metric_patterns - mapping - optional
    ## A mapping of metrics to include or exclude, with each entry being a regular expression.
    ##
    ## Metrics defined in `exclude` will take precedence in case of overlap.
    #
    # metric_patterns:
    #   include:
    #   - <INCLUDE_REGEX>
    #   exclude:
    #   - <EXCLUDE_REGEX>

## Log Section
##
## type - required - Type of log input source (tcp / udp / file / windows_event).
## port / path / channel_path - required - Set port if type is tcp or udp.
##                                         Set path if type is file.
##                                         Set channel_path if type is windows_event.
## source  - required - Attribute that defines which integration sent the logs.
## encoding - optional - For file specifies the file encoding. Default is utf-8. Other
##                       possible values are utf-16-le and utf-16-be.
## service - optional - The name of the service that generates the log.
##                      Overrides any `service` defined in the `init_config` section.
## tags - optional - Add tags to the collected logs.
##
## Discover Datadog log collection: https://docs.datadoghq.com/logs/log_collection/
#
# logs:
#   - type: file
#     source: ibm_db2
#     path: /home/db2inst1/sqllib/db2dump/db2diag.log
#     log_processing_rules:
#     - type: multi_line
#       name: new_log_start_with_date
#       pattern: \d{4}\-(0?[1-9]|[12][0-9]|3[01])\-(0?[1-9]|1[012])
