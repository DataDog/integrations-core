          {
            "id": 3006,
            "definition": {
              "title": "Agent RPC Avg Latency by Sandbox (ms)",
              "title_size": "16",
              "title_align": "left",
              "show_legend": true,
              "legend_layout": "auto",
              "legend_columns": ["avg", "max", "value"],
              "type": "timeseries",
              "requests": [
                {
                  "response_format": "timeseries",
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "sum_rate",
                      "query": "avg:kata.shim.agent.rpc.durations.histogram.milliseconds.sum{$cluster_name,$node_name,$namespace,$pod_name,$sandbox_id} by {sandbox_id,action}.as_rate()"
                    },
                    {
                      "data_source": "metrics",
                      "name": "count_rate",
                      "query": "avg:kata.shim.agent.rpc.durations.histogram.milliseconds.count{$cluster_name,$node_name,$namespace,$pod_name,$sandbox_id} by {sandbox_id,action}.as_rate()"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "sum_rate / count_rate",
                      "alias": "avg latency (ms)"
                    }
                  ],
                  "style": { "palette": "purple", "line_type": "solid", "line_width": "normal" },
                  "display_type": "line"
                }
              ]
            },
            "layout": { "x": 0, "y": 4, "width": 6, "height": 3 }
