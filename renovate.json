{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabledManagers": [
    "github-actions"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchFileNames": [
        ".github/workflows/**",
        ".github/actions/tag-job/**"
      ],
      "matchPackageNames": [
        "!dtolnay/rust-toolchain"
      ],
      "groupName": "actions",
      "schedule": [
        "before 6am on Monday"
      ],
      "labels": [
        "renovate/actions",
        "qa/skip-qa"
      ],
      "minimumReleaseAge": "7 days"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchPackageNames": [
        "python"
      ],
      "enabled": false
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchPackageNames": [
        "dtolnay/rust-toolchain"
      ],
      "groupName": "actions",
      "schedule": [
        "before 6am on Monday"
      ],
      "labels": [
        "renovate/actions",
        "qa/skip-qa"
      ]
    }
  ]
}
