        ],
        "show_title": true
      },
      "layout": {
        "x": 0,
        "y": 7,
        "width": 12,
        "height": 11
      }
    },
    {
      "definition": {
        "title": "Flow Throughput",
        "type": "group",
        "background_color": "white",
        "layout_type": "ordered",
        "widgets": [
          {
            "definition": {
              "type": "note",
              "content": "Data moving through process groups (default: root). FlowFiles transferred and bytes read/written are per-collection-interval snapshots; processor run-status counts flag stopped or invalid processors that block the flow.",
              "background_color": "white",
              "font_size": "14",
              "text_align": "left",
              "show_tick": false,
              "tick_pos": "50%",
              "tick_edge": "left",
              "has_padding": true
            },
            "layout": {
              "x": 0,
              "y": 0,
              "width": 12,
              "height": 1
            }
          },
          {
            "definition": {
              "title": "FlowFiles transferred",
              "title_size": "16",
              "title_align": "left",
              "type": "timeseries",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "query1",
                      "query": "sum:nifi.process_group.flowfiles_transferred{$host,$nifi_version,$process_group_name}"
                    },
                    {
                      "data_source": "metrics",
                      "name": "query2",
                      "query": "sum:nifi.process_group.flowfiles_received{$host,$nifi_version,$process_group_name}"
                    },
                    {
                      "data_source": "metrics",
                      "name": "query3",
