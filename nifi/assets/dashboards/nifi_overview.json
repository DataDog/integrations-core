{
    "title": "NiFi Overview",
    "description": "Overview of Apache NiFi health, flow throughput, and queue status.",
    "widgets": [
        {
            "id": 0,
            "definition": {
                "title": "Can Connect",
                "type": "query_value",
                "requests": [
                    {
                        "q": "avg:nifi.can_connect{*}",
                        "aggregator": "last"
                    }
                ],
                "precision": 0
            },
            "layout": {"x": 0, "y": 0, "width": 2, "height": 2}
        },
        {
            "id": 1,
            "definition": {
                "title": "JVM Heap Utilization",
                "type": "timeseries",
                "requests": [
                    {
                        "q": "avg:nifi.system.jvm.heap_utilization{*}",
                        "display_type": "line"
                    }
                ]
            },
            "layout": {"x": 2, "y": 0, "width": 5, "height": 2}
        },
        {
            "id": 2,
            "definition": {
                "title": "Flow - Running Processors",
                "type": "query_value",
                "requests": [
                    {
                        "q": "avg:nifi.flow.running_count{*}",
                        "aggregator": "last"
                    }
                ],
                "precision": 0
            },
            "layout": {"x": 7, "y": 0, "width": 2, "height": 2}
        },
        {
            "id": 3,
            "definition": {
                "title": "FlowFiles Queued",
                "type": "timeseries",
                "requests": [
                    {
                        "q": "avg:nifi.flow.flowfiles_queued{*}",
                        "display_type": "bars"
                    }
                ]
            },
            "layout": {"x": 0, "y": 2, "width": 4, "height": 2}
        },
        {
            "id": 4,
            "definition": {
                "title": "GC Collection Rate",
                "type": "timeseries",
                "requests": [
                    {
                        "q": "sum:nifi.system.gc.collection_count{*} by {gc_name}.as_rate()",
                        "display_type": "line"
                    }
                ]
            },
            "layout": {"x": 4, "y": 2, "width": 5, "height": 2}
        },
        {
            "id": 5,
            "definition": {
                "title": "Active Threads",
                "type": "timeseries",
                "requests": [
                    {
                        "q": "avg:nifi.flow.active_threads{*}",
                        "display_type": "line"
                    }
                ]
            },
            "layout": {"x": 0, "y": 4, "width": 4, "height": 2}
        },
        {
            "id": 6,
            "definition": {
                "title": "Repository Utilization",
                "type": "timeseries",
                "requests": [
                    {
                        "q": "avg:nifi.system.flowfile_repo.utilization{*}",
                        "display_type": "line"
                    },
                    {
                        "q": "avg:nifi.system.content_repo.utilization{*}",
                        "display_type": "line"
                    }
                ]
            },
            "layout": {"x": 4, "y": 4, "width": 5, "height": 2}
        },
        {
            "id": 7,
            "definition": {
                "title": "Cluster - Connected Nodes",
                "type": "query_value",
                "requests": [
                    {
                        "q": "max:nifi.cluster.connected_node_count{*}",
                        "aggregator": "last"
                    }
                ],
                "precision": 0
            },
            "layout": {"x": 0, "y": 6, "width": 2, "height": 2}
        },
        {
            "id": 8,
            "definition": {
                "title": "Cluster - Is Healthy",
                "type": "query_value",
                "requests": [
                    {
                        "q": "min:nifi.cluster.is_healthy{*}",
                        "aggregator": "last",
                        "conditional_formats": [
                            {"comparator": "<", "value": 1, "palette": "white_on_red"},
                            {"comparator": ">=", "value": 1, "palette": "white_on_green"}
                        ]
                    }
                ],
                "precision": 0
            },
            "layout": {"x": 2, "y": 6, "width": 2, "height": 2}
        },
        {
            "id": 9,
            "definition": {
                "title": "Bytes Queued",
                "type": "timeseries",
                "requests": [
                    {
                        "q": "sum:nifi.flow.bytes_queued{*}",
                        "display_type": "area"
                    }
                ]
            },
            "layout": {"x": 4, "y": 6, "width": 5, "height": 2}
        },
        {
            "id": 10,
            "definition": {
                "title": "Processor Status Breakdown",
                "type": "timeseries",
                "requests": [
                    {
                        "q": "avg:nifi.flow.running_count{*}",
                        "display_type": "line",
                        "style": {"palette": "green"}
                    },
                    {
                        "q": "avg:nifi.flow.stopped_count{*}",
                        "display_type": "line",
                        "style": {"palette": "gray"}
                    },
                    {
                        "q": "avg:nifi.flow.invalid_count{*}",
                        "display_type": "line",
                        "style": {"palette": "warm"}
                    },
                    {
                        "q": "avg:nifi.flow.disabled_count{*}",
                        "display_type": "line",
                        "style": {"palette": "cool"}
                    }
                ]
            },
            "layout": {"x": 0, "y": 8, "width": 4, "height": 2}
        },
        {
            "id": 11,
            "definition": {
                "title": "Top Connections by Backpressure (Count)",
                "type": "toplist",
                "requests": [
                    {
                        "q": "top(avg:nifi.connection.percent_use_count{*} by {connection_name}, 10, 'mean', 'desc')"
                    }
                ]
            },
            "layout": {"x": 4, "y": 8, "width": 5, "height": 2}
        }
    ],
    "template_variables": [],
    "layout_type": "ordered",
    "notify_list": []
}
