    {
      "definition": {
        "title": "Queue Health",
        "type": "group",
        "background_color": "vivid_orange",
        "layout_type": "ordered",
        "widgets": [
          {
            "definition": {
              "type": "note",
              "content": "Queue depth and backpressure. **Top connections** and **backpressure** require `collect_connection_metrics: true`; without it, rely on the always-on flow-level queue depth above. Backpressure approaching 100% means a connection is throttling its upstream processors.",
              "background_color": "orange",
              "font_size": "14",
              "text_align": "left",
              "show_tick": false,
              "tick_pos": "50%",
              "tick_edge": "left",
              "has_padding": true
            },
            "layout": {
