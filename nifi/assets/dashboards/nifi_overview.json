                      "formula": "query1",
                      "alias": "Transferred"
                    },
                    {
                      "formula": "query2",
                      "alias": "Received"
                    },
                    {
                      "formula": "query3",
                      "alias": "Sent"
                    }
                  ],
                  "style": {
                    "palette": "dog_classic",
                    "line_type": "solid",
                    "line_width": "normal"
                  }
                }
              ],
              "legend_columns": [
