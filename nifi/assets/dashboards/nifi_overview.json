              ],
              "legend_columns": [
                "avg",
                "min",
                "max",
                "value",
                "sum"
              ],
              "legend_layout": "auto"
            },
            "layout": {
              "x": 0,
              "y": 4,
              "width": 6,
              "height": 3
            }
          },
          {
            "definition": {
              "title": "GC time",
              "title_size": "16",
