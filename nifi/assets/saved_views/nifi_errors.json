{
    "name": "NiFi Error Logs",
    "type": "logs",
    "page": "stream",
    "query": "source:nifi status:(error OR warn)",
    "timerange": {
        "interval_ms": 3600000
    },
    "visible_facets": [
        "source",
        "host",
        "service",
        "status",
        "@logger.name",
        "@logger.thread_name"
    ],
    "options": {
        "columns": [
            "status",
            "host",
            "@logger.name"
        ],
        "show_date_column": true,
        "show_message_column": true,
        "message_display": "inline",
        "show_timeline": true
    }
}
