{
    "name": "NiFi Access Logs",
    "type": "logs",
    "page": "stream",
    "query": "source:nifi log_type:request",
    "timerange": {
        "interval_ms": 3600000
    },
    "visible_facets": [
        "source",
        "host",
        "service",
        "status",
        "@http.status_code",
        "@http.method",
        "@http.url_details.path",
        "@network.client.ip"
    ],
    "options": {
        "columns": [
            "status",
            "@http.method",
            "@http.url_details.path",
            "@http.status_code"
        ],
        "show_date_column": true,
        "show_message_column": true,
        "message_display": "inline",
        "show_timeline": true
    }
}
