{
  "title": "Kubernetes GPU Cost Overview",
  "description": "Monitor GPU cost allocation across Kubernetes clusters, including unused GPU capacity (cluster idle and workload idle), namespace-level attribution, and workload cost breakdowns.",
  "widgets": [
    {
      "id": 8118165145589911,
      "definition": {
        "title": "GPU Spend by Cluster (past 1 month)",
        "time": {
          "type": "live",
          "unit": "month",
          "value": 1,
          "hide_incomplete_cost_data": true
        },
        "comparison_time": {
          "hide_incomplete_cost_data": true
        },
        "type": "cloud_cost_summary",
        "requests": [
          {
            "response_format": "timeseries",
            "queries": [
              {
                "data_source": "cloud_cost",
                "name": "query1",
                "query": "sum:all.cost{allocated_resource:gpu,$team,$kube_cluster_name} by {kube_cluster_name}.rollup(sum, daily)"
              }
            ],
            "formulas": [
              {"formula": "query1"}
            ]
          }
        ],
        "graph_options": [
          {"type": "query_value", "view": "total"},
          {"type": "query_value", "view": "change"},
          {"type": "timeseries", "display_type": "bars"},
          {"type": "cloud_cost_table", "view": "summary", "sort": {"type": "formula", "index": 0, "order": "desc"}}
        ]
      },
      "layout": {
        "x": 0,
        "y": 0,
        "width": 12,
        "height": 4
      }
    },
