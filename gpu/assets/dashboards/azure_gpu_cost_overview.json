          {
            "id": 1817636670988685,
            "definition": {
              "title": "Azure GPU Spend by Instance Type",
              "title_size": "16",
              "title_align": "left",
              "time": {
                "hide_incomplete_cost_data": true
              },
              "type": "query_table",
              "requests": [
                {
                  "queries": [
                    {
                      "aggregator": "sum",
                      "data_source": "cloud_cost",
                      "name": "query1",
                      "query": "sum:azure.cost.amortized.shared.resources.allocated{chargetype IN (Usage) AND azure_product:VirtualMachines AND metersubcategory:*N* AND azure_pricing_term:OnDemand AND $region AND $team} by {azure_instance_type}.rollup(sum, daily)"
                    },
                    {
                      "aggregator": "sum",
                      "data_source": "cloud_cost",
                      "name": "query2",
                      "query": "sum:azure.cost.amortized.shared.resources.allocated{chargetype IN (Usage) AND azure_product:VirtualMachines AND metersubcategory:*N* AND azure_pricing_term:SavingsPlan AND $region AND $team} by {azure_instance_type}.rollup(sum, daily)"
                    },
                    {
                      "aggregator": "sum",
                      "data_source": "cloud_cost",
                      "name": "query3",
                      "query": "sum:azure.cost.amortized.shared.resources.allocated{chargetype IN (Usage) AND azure_product:VirtualMachines AND metersubcategory:*N* AND azure_pricing_term:Spot AND $region AND $team} by {azure_instance_type}.rollup(sum, daily)"
                    }
                  ],
                  "response_format": "scalar",
                  "sort": {
                    "count": 500,
                    "order_by": [
                      {
                        "index": 3,
                        "order": "desc",
                        "type": "formula"
                      }
                    ]
                  },
                  "formulas": [
                    {
                      "alias": "On-Demand %",
                      "cell_display_mode": "bar",
                      "formula": "query1 / (query1 + query2 + query3) * 100",
                      "number_format": {
                        "unit": {
                          "type": "canonical_unit",
                          "unit_name": "percent"
                        }
                      }
                    },
                    {
                      "alias": "Savings Plan %",
                      "cell_display_mode": "bar",
                      "formula": "query2 / (query1 + query2 + query3) * 100",
                      "number_format": {
                        "unit": {
                          "type": "canonical_unit",
                          "unit_name": "percent"
                        }
                      }
                    },
                    {
                      "alias": "Spot %",
                      "cell_display_mode": "bar",
                      "formula": "query3 / (query1 + query2 + query3) * 100",
                      "number_format": {
                        "unit": {
                          "type": "canonical_unit",
                          "unit_name": "percent"
                        }
                      }
                    },
                    {
                      "alias": "Total",
                      "formula": "query1 + query2 + query3",
                      "number_format": {
                        "unit": {
                          "type": "canonical_unit",
                          "unit_name": "dollar"
                        }
                      }
                    }
                  ]
                }
              ],
              "has_search_bar": "auto"
            },
            "layout": {
              "x": 0,
