{
  "title": "Azure GPU Cost Overview",
  "description": "Use this dashboard to investigate Azure GPU compute spend, understand where spend is concentrated across N-series VM families and pricing terms, and correlate costs with GPU hardware utilization.",
  "widgets": [
    {
      "id": 5720001287453536,
      "definition": {
        "title": "Azure GPU Spend",
        "background_color": "vivid_green",
        "show_title": true,
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "id": 3011001287453001,
            "definition": {
              "title": "Azure GPU Spend by Instance Type (past 1 month)",
              "time": {
                "type": "live",
                "unit": "month",
                "value": 1,
                "hide_incomplete_cost_data": true
              },
              "comparison_time": {
                "hide_incomplete_cost_data": true
              },
              "type": "cloud_cost_summary",
              "requests": [
                {
                  "response_format": "timeseries",
                  "queries": [
                    {
                      "data_source": "cloud_cost",
                      "name": "query1",
                      "query": "sum:azure.cost.amortized.shared.resources.allocated{chargetype IN (Usage) AND azure_product:VirtualMachines AND metersubcategory:*N* AND $region AND $team} by {azure_instance_type}.rollup(sum, daily)"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "query1"
                    }
                  ]
                }
              ],
              "graph_options": [
                {
                  "type": "query_value",
                  "view": "total"
