      "definition": {
        "title": "GPU Utilization & Efficiency",
        "background_color": "vivid_green",
        "show_title": true,
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "id": 3011001287453101,
            "definition": {
              "title": "Avg GPU Compute Utilization",
              "title_size": "16",
              "title_align": "left",
              "type": "query_value",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "query1",
                      "query": "avg:gpu.sm_active{cloud_provider:azure AND $region AND $team}",
                      "aggregator": "avg"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "query1",
                      "number_format": {
                        "unit": {
                          "type": "canonical_unit",
                          "unit_name": "percent"
                        }
                      }
                    }
                  ],
                  "response_format": "scalar",
                  "conditional_formats": [
                    {
                      "comparator": ">=",
                      "value": 60,
                      "palette": "white_on_green"
                    },
                    {
                      "comparator": ">=",
                      "value": 30,
                      "palette": "white_on_yellow"
                    },
                    {
                      "comparator": "<",
                      "value": 30,
                      "palette": "white_on_red"
                    }
                  ]
                }
              ],
              "autoscale": true,
              "precision": 1,
              "timeseries_background": {
