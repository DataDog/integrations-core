                },
                {
                  "type": "cloud_cost_table",
                  "view": "summary",
                  "sort": {
                    "type": "formula",
                    "index": 0,
                    "order": "desc"
                  }
                }
              ]
            },
            "layout": {
              "x": 0,
              "y": 0,
              "width": 12,
              "height": 6
            }
