          {
            "id": 7163297225224222,
            "definition": {
              "title": "Azure On-Demand % of GPU Spend",
              "title_size": "16",
              "title_align": "left",
              "show_legend": true,
              "legend_layout": "horizontal",
              "legend_columns": [
                "avg",
                "min",
                "max",
                "value",
                "sum"
              ],
              "time": {
                "hide_incomplete_cost_data": true
              },
              "type": "timeseries",
              "requests": [
                {
                  "formulas": [
                    {
                      "alias": "On-Demand %",
                      "formula": "100 * (query2 / query1)",
                      "style": {
                        "palette": "blue",
                        "palette_index": 4
                      }
                    }
                  ],
                  "queries": [
                    {
                      "data_source": "cloud_cost",
                      "name": "query2",
                      "query": "sum:azure.cost.amortized.shared.resources.allocated{chargetype IN (Usage) AND azure_product:VirtualMachines AND metersubcategory:*N* AND azure_pricing_term:OnDemand AND $region AND $team}.rollup(sum, daily)"
                    },
                    {
                      "data_source": "cloud_cost",
                      "name": "query1",
                      "query": "sum:azure.cost.amortized.shared.resources.allocated{chargetype IN (Usage) AND azure_product:VirtualMachines AND metersubcategory:*N* AND $region AND $team}.rollup(sum, daily)"
                    }
                  ],
                  "response_format": "timeseries",
                  "style": {
                    "order_by": "values",
                    "palette": "dog_classic",
                    "line_type": "solid",
                    "line_width": "normal"
                  },
                  "display_type": "line"
                }
              ]
            },
            "layout": {
              "x": 6,
              "y": 8,
              "width": 6,
              "height": 3
            }
