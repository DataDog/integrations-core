                        }
                      }
                    }
                  ],
                  "queries": [
                    {
                      "data_source": "cloud_cost",
                      "name": "query5",
                      "query": "sum:all.cost{((allocated_resource:gpu AND allocated_spend_type IN (cluster_idle,workload_idle)) OR (aws_instance_family IN (\"GPU instance\",\"Machine Learning ASIC Instances\") AND aws_usage_type:*Unused*)) AND $availability-zone AND $team AND $kube_cluster_name}.rollup(sum, daily)"
                    },
                    {
                      "data_source": "cloud_cost",
                      "name": "query1",
                      "query": "sum:aws.cost.net.amortized.shared.resources.allocated{aws_instance_family IN (\"GPU instance\",\"Machine Learning ASIC Instances\") AND $availability-zone AND $team AND $kube_cluster_name}.rollup(sum, daily)"
                    },
                    {
                      "data_source": "cloud_cost",
                      "name": "query2",
                      "query": "sum:azure.cost.amortized.shared.resources.allocated{chargetype IN (Usage) AND azure_product:VirtualMachines AND metersubcategory:*N* AND $availability-zone AND $team AND $kube_cluster_name}.rollup(sum, daily)"
