    {
      "id": 6079930088570004,
      "definition": {
        "title": "MoM Change",
        "title_size": "16",
        "title_align": "left",
        "time": {
          "type": "live",
          "unit": "month",
          "value": 1,
          "hide_incomplete_cost_data": true
        },
        "type": "query_value",
        "requests": [
          {
            "formulas": [
              {
                "number_format": {
                  "unit": {
                    "type": "canonical_unit",
                    "unit_name": "percent"
                  }
                },
                "formula": "((query1 + query2 + query3) - (timeshift(query4, -2592000) + timeshift(query5, -2592000) + timeshift(query6, -2592000))) / (timeshift(query4, -2592000) + timeshift(query5, -2592000) + timeshift(query6, -2592000)) * 100"
              }
            ],
            "queries": [
              {
                "aggregator": "sum",
                "data_source": "cloud_cost",
                "name": "query1",
                "query": "sum:aws.cost.net.amortized.shared.resources.allocated{(aws_instance_family IN (\"GPU instance\",\"Machine Learning ASIC Instances\")) AND $availability-zone AND $team AND $kube_cluster_name}"
              },
              {
                "aggregator": "sum",
                "data_source": "cloud_cost",
                "name": "query2",
                "query": "sum:azure.cost.amortized.shared.resources.allocated{chargetype IN (Usage) AND azure_product:VirtualMachines AND metersubcategory:*N* AND $availability-zone AND $team AND $kube_cluster_name}"
              },
              {
                "aggregator": "sum",
                "data_source": "cloud_cost",
                "name": "query3",
                "query": "sum:gcp.cost.amortized.shared.resources.allocated{NOT credits_type:PROMOTION AND NOT google_usage_type:*PD* AND NOT google_usage_type:*Transfer* AND (google_usage_type:*GPU* OR compute.googleapis.com/machine_spec:*a2* OR compute.googleapis.com/machine_spec:*g2* OR compute.googleapis.com/machine_spec:*a3*) AND $availability-zone AND $team AND $kube_cluster_name}"
              },
              {
                "aggregator": "sum",
                "data_source": "cloud_cost",
                "name": "query4",
                "query": "sum:aws.cost.net.amortized.shared.resources.allocated{(aws_instance_family IN (\"GPU instance\",\"Machine Learning ASIC Instances\")) AND $availability-zone AND $team AND $kube_cluster_name}"
              },
              {
                "aggregator": "sum",
                "data_source": "cloud_cost",
                "name": "query5",
                "query": "sum:azure.cost.amortized.shared.resources.allocated{chargetype IN (Usage) AND azure_product:VirtualMachines AND metersubcategory:*N* AND $availability-zone AND $team AND $kube_cluster_name}"
              },
              {
                "aggregator": "sum",
                "data_source": "cloud_cost",
                "name": "query6",
                "query": "sum:gcp.cost.amortized.shared.resources.allocated{NOT credits_type:PROMOTION AND NOT google_usage_type:*PD* AND NOT google_usage_type:*Transfer* AND (google_usage_type:*GPU* OR compute.googleapis.com/machine_spec:*a2* OR compute.googleapis.com/machine_spec:*g2* OR compute.googleapis.com/machine_spec:*a3*) AND $availability-zone AND $team AND $kube_cluster_name}"
              }
            ],
            "response_format": "scalar",
            "conditional_formats": [
              {
                "comparator": "<",
                "value": 1,
                "palette": "black_on_light_green"
              },
              {
                "comparator": "<",
                "value": 10,
                "palette": "black_on_light_yellow"
              },
              {
                "comparator": "<",
                "value": 100,
                "palette": "black_on_light_red"
              },
              {
                "comparator": ">=",
                "value": 100,
                "palette": "white_on_red"
              }
            ]
          }
        ],
        "autoscale": true,
        "precision": 2,
        "timeseries_background": {
          "yaxis": {
            "include_zero": true
          },
          "type": "area"
