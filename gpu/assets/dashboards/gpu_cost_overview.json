    {
      "id": 4870940906334069,
      "definition": {
        "title": "Cost of Unused GPU",
        "background_color": "vivid_green",
        "show_title": true,
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "id": 8998298117813549,
            "definition": {
              "type": "note",
              "content": "Unused GPU Spend **includes**:\n- Cluster idle cost (unallocated GPU capacity)\n- Workload idle cost (allocated but underutilized)\n- Unused On-Demand Capacity Reservations (AWS)",
              "background_color": "green",
              "font_size": "14",
              "text_align": "left",
              "vertical_align": "center",
              "show_tick": false,
              "has_padding": true
            },
            "layout": {
              "x": 0,
              "y": 0,
              "width": 3,
              "height": 2
            }
          },
          {
            "id": 5548338680663049,
            "definition": {
              "title": "Total Cost of Unused GPU",
              "title_size": "16",
              "title_align": "left",
              "time": {
                "type": "live",
                "unit": "month",
                "value": 1,
                "hide_incomplete_cost_data": true
              },
              "type": "query_value",
              "requests": [
                {
                  "formulas": [
                    {
                      "formula": "query1 + query2",
                      "number_format": {
                        "unit": {
                          "type": "canonical_unit",
                          "unit_name": "dollar"
                        }
                      }
                    }
                  ],
                  "queries": [
                    {
                      "aggregator": "sum",
                      "data_source": "cloud_cost",
                      "name": "query1",
                      "query": "sum:all.cost{allocated_spend_type IN (cluster_idle,workload_idle) AND allocated_resource:gpu AND $availability-zone AND $team AND $kube_cluster_name}"
                    },
                    {
                      "aggregator": "sum",
                      "data_source": "cloud_cost",
                      "name": "query2",
                      "query": "sum:aws.cost.net.amortized.shared.resources.allocated{aws_instance_family IN (\"GPU instance\",\"Machine Learning ASIC Instances\") AND aws_usage_type:*Unused* AND $availability-zone AND $team AND $kube_cluster_name}"
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "autoscale": true,
              "precision": 2,
              "timeseries_background": {
                "type": "area"
              }
            },
            "layout": {
              "x": 3,
              "y": 0,
              "width": 3,
              "height": 2
            }
          },
          {
            "id": 518871954469655,
            "definition": {
              "title": "% of GPU Spend Unused",
              "title_size": "16",
              "title_align": "left",
              "time": {
                "hide_incomplete_cost_data": true
              },
              "type": "query_value",
              "requests": [
                {
                  "formulas": [
                    {
                      "formula": "query5 / (query1 + query2 + query3) * 100",
                      "number_format": {
                        "unit": {
                          "type": "canonical_unit",
                          "unit_name": "percent"
                        }
                      }
                    }
                  ],
                  "queries": [
                    {
                      "aggregator": "sum",
                      "data_source": "cloud_cost",
                      "name": "query5",
                      "query": "sum:all.cost{((allocated_resource:gpu AND allocated_spend_type IN (cluster_idle,workload_idle)) OR (aws_instance_family IN (\"GPU instance\",\"Machine Learning ASIC Instances\") AND aws_usage_type:*Unused*)) AND $availability-zone AND $team AND $kube_cluster_name}"
                    },
                    {
                      "aggregator": "sum",
                      "data_source": "cloud_cost",
                      "name": "query1",
                      "query": "sum:aws.cost.net.amortized.shared.resources.allocated{aws_instance_family IN (\"GPU instance\",\"Machine Learning ASIC Instances\") AND $availability-zone AND $team AND $kube_cluster_name}"
                    },
                    {
                      "aggregator": "sum",
                      "data_source": "cloud_cost",
                      "name": "query2",
                      "query": "sum:azure.cost.amortized.shared.resources.allocated{chargetype IN (Usage) AND azure_product:VirtualMachines AND metersubcategory:*N* AND $availability-zone AND $team AND $kube_cluster_name}"
                    },
                    {
                      "aggregator": "sum",
                      "data_source": "cloud_cost",
                      "name": "query3",
                      "query": "sum:gcp.cost.amortized.shared.resources.allocated{NOT credits_type:PROMOTION AND NOT google_usage_type:*PD* AND NOT google_usage_type:*Transfer* AND (google_usage_type:*GPU* OR compute.googleapis.com/machine_spec:*a2* OR compute.googleapis.com/machine_spec:*g2* OR compute.googleapis.com/machine_spec:*a3*) AND $availability-zone AND $team AND $kube_cluster_name}"
                    }
                  ],
                  "response_format": "scalar",
                  "conditional_formats": [
                    {
                      "comparator": ">",
                      "value": 30,
                      "palette": "white_on_red"
                    },
                    {
                      "comparator": ">",
                      "value": 15,
                      "palette": "white_on_yellow"
                    },
                    {
                      "comparator": "<=",
                      "value": 15,
                      "palette": "white_on_green"
                    }
                  ]
                }
              ],
              "autoscale": false,
              "precision": 1,
              "timeseries_background": {
                "type": "area"
              }
            },
            "layout": {
              "x": 6,
              "y": 0,
              "width": 3,
              "height": 2
            }
          },
          {
            "id": 7319329847932256,
            "definition": {
              "title": "Idle GPU Cost Breakdown",
              "title_size": "16",
              "title_align": "left",
              "time": {
                "hide_incomplete_cost_data": true
              },
              "type": "query_table",
              "requests": [
                {
                  "queries": [
                    {
                      "aggregator": "sum",
                      "data_source": "cloud_cost",
                      "name": "query1",
                      "query": "sum:all.cost{allocated_resource:gpu,allocated_spend_type:cluster_idle,$availability-zone,$team,$kube_cluster_name}"
                    },
                    {
                      "aggregator": "sum",
                      "data_source": "cloud_cost",
                      "name": "query2",
                      "query": "sum:all.cost{allocated_resource:gpu,allocated_spend_type:workload_idle,$availability-zone,$team,$kube_cluster_name}"
                    },
                    {
                      "aggregator": "sum",
                      "data_source": "cloud_cost",
                      "name": "query3",
                      "query": "sum:aws.cost.net.amortized.shared.resources.allocated{aws_instance_family IN (\"GPU instance\",\"Machine Learning ASIC Instances\") AND aws_usage_type:*Unused* AND $availability-zone AND $team AND $kube_cluster_name}"
                    }
                  ],
                  "response_format": "scalar",
                  "sort": {
                    "count": 500,
                    "order_by": [
                      {
                        "index": 3,
                        "order": "desc",
                        "type": "formula"
                      }
                    ]
                  },
                  "formulas": [
                    {
                      "alias": "Cluster Idle",
                      "cell_display_mode": "bar",
                      "formula": "query1"
                    },
                    {
                      "alias": "Workload Idle",
