{
  "title": "AWS GPU Cost Overview",
  "description": "Monitor AWS GPU compute spend including instance type breakdowns, On-Demand vs committed pricing coverage, and cost trends.",
  "widgets": [
    {
      "id": 4035703146780275,
      "definition": {
        "title": "AWS GPU Spend",
        "background_color": "vivid_green",
        "show_title": true,
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "id": 400177514017573,
            "definition": {
              "title": "AWS GPU Spend",
              "title_size": "16",
              "title_align": "left",
              "time": {
                "hide_incomplete_cost_data": true
              },
              "type": "query_value",
              "requests": [
                {
                  "formulas": [
                    {
                      "formula": "query1",
                      "number_format": {
                        "unit": {
                          "type": "canonical_unit",
                          "unit_name": "dollar"
                        }
                      }
                    }
                  ],
                  "queries": [
                    {
                      "aggregator": "sum",
                      "data_source": "cloud_cost",
                      "name": "query1",
                      "query": "sum:aws.cost.net.amortized.shared.resources.allocated{(aws_instance_family IN (\"GPU instance\",\"Machine Learning ASIC Instances\")) AND $availability-zone AND $team AND $kube_cluster_name}"
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "autoscale": true,
              "precision": 2,
              "timeseries_background": {
                "type": "area"
              }
            },
            "layout": {
              "x": 0,
              "y": 0,
              "width": 3,
              "height": 2
            }
          },
          {
            "id": 8701257412207113,
            "definition": {
              "type": "note",
              "content": "AWS GPU instances include the **GPU instance** and **Machine Learning ASIC Instances** families (p3, p4, p5, g4, g5, g6, inf1, inf2, trn1, dl1, and more). Coverage shows On-Demand vs committed spend. On-demand % tracks how much GPU spend is at on-demand rates.",
              "background_color": "green",
              "font_size": "14",
              "text_align": "left",
              "vertical_align": "center",
              "show_tick": false,
              "has_padding": true
            },
            "layout": {
              "x": 3,
              "y": 0,
              "width": 9,
              "height": 2
            }
          },
          {
            "id": 4934879187088526,
            "definition": {
              "title": "AWS GPU Coverage by Cost Type",
              "title_size": "16",
              "title_align": "left",
              "show_legend": true,
              "legend_layout": "auto",
              "legend_columns": [
                "avg",
                "min",
                "max",
                "value",
                "sum"
              ],
              "time": {
                "hide_incomplete_cost_data": true
              },
              "type": "timeseries",
              "requests": [
                {
                  "formulas": [
                    {
                      "formula": "query1"
                    }
                  ],
                  "queries": [
                    {
                      "data_source": "cloud_cost",
                      "name": "query1",
                      "query": "sum:all.cost{providername IN (aws) AND aws_instance_family IN (\"GPU instance\",\"Machine Learning ASIC Instances\") AND $availability-zone AND $team AND $kube_cluster_name} by {aws_cost_type}.rollup(sum, daily)"
                    }
                  ],
                  "response_format": "timeseries",
                  "style": {
                    "color_order": "monotonic",
                    "order_by": "values",
                    "order_reverse": false,
                    "palette": "dog_classic",
                    "line_type": "solid",
                    "line_width": "normal"
                  },
                  "display_type": "bars"
                }
              ]
            },
            "layout": {
              "x": 0,
              "y": 2,
              "width": 6,
              "height": 3
            }
          },
          {
            "id": 208881602918064,
            "definition": {
              "title": "AWS On-Demand % of GPU Spend",
              "title_size": "16",
              "title_align": "left",
              "show_legend": true,
              "legend_layout": "auto",
              "legend_columns": [
                "avg",
                "min",
                "max",
                "value",
                "sum"
              ],
              "time": {
                "hide_incomplete_cost_data": true
              },
              "type": "timeseries",
              "requests": [
                {
                  "formulas": [
                    {
                      "alias": "On-Demand %",
                      "formula": "100 * (query2 / query1)",
                      "style": {
                        "palette": "blue",
                        "palette_index": 4
                      }
                    }
                  ],
                  "queries": [
                    {
                      "data_source": "cloud_cost",
                      "name": "query2",
                      "query": "sum:all.cost{providername IN (aws) AND aws_instance_family IN (\"GPU instance\",\"Machine Learning ASIC Instances\") AND aws_cost_type:Usage AND $availability-zone AND $team AND $kube_cluster_name}.rollup(sum, daily)"
                    },
                    {
                      "data_source": "cloud_cost",
                      "name": "query1",
                      "query": "sum:all.cost{providername IN (aws) AND aws_instance_family IN (\"GPU instance\",\"Machine Learning ASIC Instances\") AND $availability-zone AND $team AND $kube_cluster_name}.rollup(sum, daily)"
                    }
                  ],
                  "response_format": "timeseries",
                  "style": {
                    "color_order": "monotonic",
                    "order_by": "values",
                    "order_reverse": false,
                    "palette": "dog_classic",
                    "line_type": "solid",
                    "line_width": "normal"
                  },
                  "display_type": "line"
                }
              ]
            },
            "layout": {
              "x": 6,
              "y": 2,
              "width": 6,
              "height": 3
            }
          },
          {
            "id": 500519145286225,
            "definition": {
              "title": "AWS GPU Spend by Instance Type",
              "title_size": "16",
              "title_align": "left",
              "time": {
                "hide_incomplete_cost_data": true
              },
              "type": "query_table",
              "requests": [
                {
                  "queries": [
                    {
                      "aggregator": "sum",
                      "data_source": "cloud_cost",
                      "name": "query1",
                      "query": "sum:aws.cost.net.amortized.shared.resources.allocated{aws_instance_family IN (\"GPU instance\",\"Machine Learning ASIC Instances\") AND aws_operation:RunInstances AND aws_usage_type:*BoxUsage* AND is_aws_ec2_compute_on_demand:true AND $availability-zone AND $team AND $kube_cluster_name} by {aws_instance_type}"
                    },
                    {
                      "aggregator": "sum",
                      "data_source": "cloud_cost",
                      "name": "query2",
                      "query": "sum:aws.cost.net.amortized.shared.resources.allocated{aws_instance_family IN (\"GPU instance\",\"Machine Learning ASIC Instances\") AND aws_operation:RunInstances AND aws_usage_type:*BoxUsage* AND NOT is_aws_ec2_compute_on_demand:true AND $availability-zone AND $team AND $kube_cluster_name} by {aws_instance_type}"
                    },
                    {
                      "aggregator": "sum",
                      "data_source": "cloud_cost",
                      "name": "query3",
                      "query": "sum:aws.cost.net.amortized.shared.resources.allocated{aws_instance_family IN (\"GPU instance\",\"Machine Learning ASIC Instances\") AND aws_operation:RunInstances AND aws_usage_type:*Unused* AND NOT is_aws_ec2_compute_on_demand:true AND $availability-zone AND $team AND $kube_cluster_name} by {aws_instance_type}"
                    }
                  ],
                  "response_format": "scalar",
                  "sort": {
                    "count": 500,
                    "order_by": [
                      {
                        "index": 3,
                        "order": "desc",
                        "type": "formula"
                      }
                    ]
                  },
                  "formulas": [
                    {
                      "alias": "On-Demand",
                      "cell_display_mode": "bar",
                      "formula": "query1"
                    },
                    {
                      "alias": "Used ODCR",
                      "cell_display_mode": "bar",
                      "formula": "query2"
                    },
                    {
                      "alias": "Unused ODCR",
                      "cell_display_mode": "bar",
                      "formula": "query3"
                    },
                    {
                      "alias": "Total",
                      "formula": "query1 + query2 + query3"
                    }
                  ]
                }
              ],
              "has_search_bar": "auto"
            },
            "layout": {
              "x": 0,
              "y": 5,
              "width": 6,
              "height": 4
            }
          },
