          {
            "id": 208881602918064,
            "definition": {
              "title": "AWS On-Demand % of GPU Spend",
              "title_size": "16",
              "title_align": "left",
              "show_legend": true,
              "legend_layout": "auto",
              "legend_columns": [
                "avg",
                "min",
                "max",
                "value",
                "sum"
              ],
              "time": {
                "hide_incomplete_cost_data": true
              },
              "type": "timeseries",
              "requests": [
                {
                  "formulas": [
                    {
                      "alias": "On-Demand %",
                      "formula": "100 * (query2 / query1)",
                      "style": {
                        "palette": "blue",
                        "palette_index": 4
                      }
                    }
                  ],
                  "queries": [
                    {
                      "data_source": "cloud_cost",
                      "name": "query2",
                      "query": "sum:all.cost{providername IN (aws) AND aws_instance_family IN (\"GPU instance\",\"Machine Learning ASIC Instances\",\"Accelerated Computing\") AND is_aws_ec2_compute_on_demand:true AND $availability-zone AND $team}.rollup(sum, daily)"
                    },
                    {
                      "data_source": "cloud_cost",
                      "name": "query1",
                      "query": "sum:all.cost{providername IN (aws) AND aws_instance_family IN (\"GPU instance\",\"Machine Learning ASIC Instances\",\"Accelerated Computing\") AND $availability-zone AND $team}.rollup(sum, daily)"
                    }
                  ],
                  "response_format": "timeseries",
                  "style": {
                    "color_order": "monotonic",
                    "order_by": "values",
                    "order_reverse": false,
                    "palette": "dog_classic",
                    "line_type": "solid",
                    "line_width": "normal"
                  },
                  "display_type": "line"
                }
              ]
            },
            "layout": {
              "x": 6,
              "y": 8,
              "width": 6,
              "height": 3
            }
          },
          {
            "id": 500519145286225,
            "definition": {
              "title": "AWS GPU Spend by Instance Type",
              "title_size": "16",
              "title_align": "left",
              "time": {
                "hide_incomplete_cost_data": true
              },
              "type": "query_table",
              "requests": [
                {
                  "queries": [
                    {
                      "aggregator": "sum",
                      "data_source": "cloud_cost",
                      "name": "query1",
                      "query": "sum:aws.cost.net.amortized.shared.resources.allocated{aws_instance_family IN (\"GPU instance\",\"Machine Learning ASIC Instances\",\"Accelerated Computing\") AND aws_operation:RunInstances AND aws_usage_type:*BoxUsage* AND is_aws_ec2_compute_on_demand:true AND $availability-zone AND $team} by {aws_instance_type}"
                    },
                    {
                      "aggregator": "sum",
                      "data_source": "cloud_cost",
                      "name": "query2",
                      "query": "sum:aws.cost.net.amortized.shared.resources.allocated{aws_instance_family IN (\"GPU instance\",\"Machine Learning ASIC Instances\",\"Accelerated Computing\") AND aws_operation:RunInstances AND aws_usage_type:*BoxUsage* AND NOT is_aws_ec2_compute_on_demand:true AND $availability-zone AND $team} by {aws_instance_type}"
                    },
                    {
                      "aggregator": "sum",
                      "data_source": "cloud_cost",
                      "name": "query3",
                      "query": "sum:aws.cost.net.amortized.shared.resources.allocated{aws_instance_family IN (\"GPU instance\",\"Machine Learning ASIC Instances\",\"Accelerated Computing\") AND aws_operation:RunInstances AND aws_usage_type:*Unused* AND NOT is_aws_ec2_compute_on_demand:true AND $availability-zone AND $team} by {aws_instance_type}"
                    }
                  ],
                  "response_format": "scalar",
                  "sort": {
                    "count": 500,
                    "order_by": [
                      {
                        "index": 3,
                        "order": "desc",
                        "type": "formula"
                      }
                    ]
                  },
                  "formulas": [
                    {
                      "alias": "On-Demand %",
                      "cell_display_mode": "bar",
                      "formula": "query1 / (query1 + query2 + query3) * 100",
                      "number_format": {
                        "unit": {
                          "type": "canonical_unit",
                          "unit_name": "percent"
                        }
                      }
                    },
                    {
                      "alias": "Used ODCR %",
                      "cell_display_mode": "bar",
                      "formula": "query2 / (query1 + query2 + query3) * 100",
                      "number_format": {
                        "unit": {
                          "type": "canonical_unit",
                          "unit_name": "percent"
                        }
                      }
                    },
                    {
                      "alias": "Unused ODCR %",
                      "cell_display_mode": "bar",
                      "formula": "query3 / (query1 + query2 + query3) * 100",
                      "number_format": {
                        "unit": {
                          "type": "canonical_unit",
                          "unit_name": "percent"
                        }
                      }
                    },
                    {
                      "alias": "Total",
                      "formula": "query1 + query2 + query3",
                      "number_format": {
                        "unit": {
                          "type": "canonical_unit",
                          "unit_name": "dollar"
                        }
                      }
                    }
                  ]
                }
              ],
              "has_search_bar": "auto"
            },
            "layout": {
              "x": 0,
              "y": 11,
              "width": 6,
              "height": 4
            }
