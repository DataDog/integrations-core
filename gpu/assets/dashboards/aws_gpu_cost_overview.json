          {
            "id": 8701257412207113,
            "definition": {
              "type": "note",
              "content": "AWS GPU instances include the **GPU instance**, **Machine Learning ASIC Instances**, and **Accelerated Computing** families (p3, p4, p5, p6, g4, g5, g6, inf1, inf2, trn1, dl1, and more). The top chart shows **amortized** spend by instance type. **Capacity Block** upfront reservations are tracked separately (AWS excludes them from amortized cost).",
              "background_color": "green",
              "font_size": "14",
              "text_align": "left",
              "vertical_align": "center",
              "show_tick": false,
              "has_padding": true
            },
            "layout": {
              "x": 6,
              "y": 6,
              "width": 6,
              "height": 2
            }
          },
          {
            "id": 4934879187088526,
            "definition": {
              "title": "AWS GPU Coverage by Cost Type",
              "title_size": "16",
              "title_align": "left",
              "show_legend": true,
              "legend_layout": "auto",
              "legend_columns": [
                "avg",
                "min",
                "max",
                "value",
