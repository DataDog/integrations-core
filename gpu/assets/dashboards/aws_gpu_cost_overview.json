{
  "title": "AWS GPU Cost Overview",
  "description": "Use this dashboard to investigate AWS GPU compute spend, understand where spend is concentrated across instance types and pricing terms, and correlate costs with GPU hardware utilization.",
  "widgets": [
    {
      "id": 4035703146780275,
      "definition": {
        "title": "AWS GPU Spend",
        "background_color": "vivid_green",
        "show_title": true,
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "id": 4035703146780300,
            "definition": {
              "title": "AWS GPU Spend by Instance Type (past 1 month)",
              "time": {
                "type": "live",
                "unit": "month",
                "value": 1,
                "hide_incomplete_cost_data": true
              },
              "comparison_time": {
                "hide_incomplete_cost_data": true
              },
              "type": "cloud_cost_summary",
              "requests": [
                {
                  "response_format": "timeseries",
                  "queries": [
                    {
                      "data_source": "cloud_cost",
                      "name": "query1",
                      "query": "sum:aws.cost.net.amortized.shared.resources.allocated{aws_instance_family IN (\"GPU instance\",\"Machine Learning ASIC Instances\",\"Accelerated Computing\") AND $availability-zone AND $team} by {aws_instance_type}.rollup(sum, daily)"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "query1"
                    }
                  ]
                }
              ],
              "graph_options": [
                {"type": "query_value", "view": "total"},
                {"type": "query_value", "view": "change"},
                {"type": "timeseries", "display_type": "bars"},
                {"type": "cloud_cost_table", "view": "summary", "sort": {"type": "formula", "index": 0, "order": "desc"}}
              ]
            },
            "layout": {
              "x": 0,
              "y": 0,
              "width": 12,
              "height": 6
            }
          },
          {
            "id": 400177514017573,
            "definition": {
              "title": "AWS GPU Spend (past 30 days)",
              "title_size": "16",
              "title_align": "left",
              "time": {
                "type": "live",
                "unit": "month",
                "value": 1,
                "hide_incomplete_cost_data": true
              },
              "type": "query_value",
              "requests": [
                {
                  "formulas": [
                    {
                      "formula": "query1 + query2",
                      "number_format": {
                        "unit": {
                          "type": "canonical_unit",
                          "unit_name": "dollar"
                        }
                      }
                    }
                  ],
                  "queries": [
                    {
                      "aggregator": "sum",
                      "data_source": "cloud_cost",
                      "name": "query1",
                      "query": "sum:aws.cost.net.amortized.shared.resources.allocated{(aws_instance_family IN (\"GPU instance\",\"Machine Learning ASIC Instances\",\"Accelerated Computing\")) AND $availability-zone AND $team}"
                    },
                    {
                      "aggregator": "sum",
                      "data_source": "cloud_cost",
                      "name": "query2",
                      "query": "sum:aws.cost.net.unblended{aws_usage_type:*CapacityBlock* AND $availability-zone AND $team}"
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "autoscale": true,
              "precision": 2,
              "timeseries_background": {
                "type": "area"
              }
            },
            "layout": {
              "x": 0,
              "y": 6,
              "width": 3,
              "height": 2
            }
          },
          {
            "id": 4035703146780301,
            "definition": {
