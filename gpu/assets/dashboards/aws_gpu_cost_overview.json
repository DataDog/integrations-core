                  "queries": [
                    {
                      "data_source": "cloud_cost",
                      "name": "query1",
                      "query": "sum:all.cost{providername IN (aws) AND aws_instance_family IN (\"GPU instance\",\"Machine Learning ASIC Instances\",\"Accelerated Computing\") AND $availability-zone AND $team} by {aws_cost_type}.rollup(sum, daily)"
