{
  "title": "GCP GPU Cost Overview",
  "description": "Use this dashboard to investigate GCP GPU compute spend, understand where spend is concentrated across machine specs and commitment models, and correlate costs with GPU hardware utilization.",
  "widgets": [
    {
      "id": 86266938490582,
      "definition": {
        "title": "GCP GPU Spend",
        "background_color": "vivid_green",
        "show_title": true,
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "id": 86266938490600,
            "definition": {
              "title": "GCP GPU Spend by SKU (past 30 days)",
              "time": {
                "type": "live",
                "unit": "month",
                "value": 1,
                "hide_incomplete_cost_data": true
              },
              "comparison_time": {
                "hide_incomplete_cost_data": true
              },
              "type": "cloud_cost_summary",
              "requests": [
                {
                  "response_format": "timeseries",
                  "queries": [
                    {
                      "data_source": "cloud_cost",
                      "name": "query1",
                      "query": "sum:gcp.cost.amortized.shared.resources.allocated{NOT credits_type:PROMOTION AND NOT google_usage_type:*PD* AND NOT google_usage_type:*Transfer* AND NOT google_usage_type:*Vertex* AND (google_usage_type:*GPU* OR compute.googleapis.com/machine_spec:*a2* OR compute.googleapis.com/machine_spec:*g2* OR compute.googleapis.com/machine_spec:*a3*) AND $zone AND $team} by {sku_description}.rollup(sum, daily)"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "query1"
                    }
                  ]
                }
              ],
              "graph_options": [
                {
                  "type": "query_value",
                  "view": "total"
                },
                {
                  "type": "query_value",
                  "view": "change"
                },
                {
                  "type": "timeseries",
                  "display_type": "bars"
                },
                {
                  "type": "cloud_cost_table",
                  "view": "summary",
                  "sort": {
                    "type": "formula",
                    "index": 0,
                    "order": "desc"
                  }
                }
              ]
            },
            "layout": {
              "x": 0,
              "y": 0,
              "width": 12,
              "height": 6
            }
          },
