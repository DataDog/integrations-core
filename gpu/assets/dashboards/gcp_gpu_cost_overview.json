                      "data_source": "cloud_cost",
                      "name": "query1",
                      "query": "sum:gcp.cost.amortized{NOT credits_type:PROMOTION AND NOT google_usage_type:*PD* AND NOT google_usage_type:*Transfer* AND (google_usage_type:*GPU* OR compute.googleapis.com/machine_spec:g2* OR compute.googleapis.com/machine_spec:a2* OR compute.googleapis.com/machine_spec:a3*) AND $availability-zone AND $team AND $kube_cluster_name}"
                    }
