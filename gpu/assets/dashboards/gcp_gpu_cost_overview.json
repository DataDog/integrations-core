                    },
                    {
                      "data_source": "cloud_cost",
                      "name": "query1",
                      "query": "sum:gcp.cost.amortized.shared.resources.allocated{NOT credits_type:PROMOTION AND NOT google_usage_type:*PD* AND NOT google_usage_type:*Transfer* AND NOT google_usage_type:*Vertex* AND (google_usage_type:*GPU* OR compute.googleapis.com/machine_spec:*g2* OR compute.googleapis.com/machine_spec:*a2* OR compute.googleapis.com/machine_spec:*a3*) AND $zone AND $team}.rollup(sum, daily)"
