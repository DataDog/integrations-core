    {
      "id": 86266938491000,
      "definition": {
        "title": "GPU Utilization & Efficiency",
        "background_color": "vivid_green",
        "show_title": true,
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "id": 86266938491001,
            "definition": {
              "title": "Average GPU Utilization %",
              "title_size": "16",
              "title_align": "left",
              "type": "query_value",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "query1",
                      "query": "avg:gpu.sm_active{cloud_provider:gcp AND $zone AND $team}",
                      "aggregator": "avg"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "query1",
                      "number_format": {
                        "unit": {
                          "type": "canonical_unit",
                          "unit_name": "percent"
                        }
                      }
                    }
                  ],
                  "response_format": "scalar",
                  "conditional_formats": [
                    {
                      "comparator": ">=",
                      "value": 60,
                      "palette": "white_on_green"
                    },
                    {
                      "comparator": ">=",
                      "value": 30,
                      "palette": "white_on_yellow"
                    },
                    {
                      "comparator": "<",
                      "value": 30,
                      "palette": "white_on_red"
                    }
                  ]
                }
              ],
              "autoscale": true,
              "precision": 1,
              "timeseries_background": {
                "type": "area"
              }
            },
            "layout": {
              "x": 0,
              "y": 0,
              "width": 4,
              "height": 2
            }
          },
          {
            "id": 86266938491002,
            "definition": {
              "title": "Active GPU Devices",
              "title_size": "16",
              "title_align": "left",
              "type": "query_value",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "query1",
                      "query": "sum:gpu.device.total{cloud_provider:gcp AND $zone AND $team}",
                      "aggregator": "last"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "query1"
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "autoscale": true,
              "precision": 0,
              "timeseries_background": {
                "type": "area"
              }
            },
            "layout": {
              "x": 4,
              "y": 0,
              "width": 4,
              "height": 2
            }
          },
          {
            "id": 86266938491003,
            "definition": {
              "title": "Average GPU Idle %",
              "title_size": "16",
              "title_align": "left",
              "type": "query_value",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "query1",
                      "query": "avg:gpu.gr_engine_active{cloud_provider:gcp AND $zone AND $team}",
                      "aggregator": "avg"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "100 - query1",
                      "number_format": {
                        "unit": {
                          "type": "canonical_unit",
                          "unit_name": "percent"
                        }
                      }
                    }
                  ],
                  "response_format": "scalar",
                  "conditional_formats": [
                    {
                      "comparator": ">=",
                      "value": 60,
                      "palette": "white_on_red"
                    },
                    {
                      "comparator": ">=",
                      "value": 30,
                      "palette": "white_on_yellow"
                    },
                    {
                      "comparator": "<",
                      "value": 30,
                      "palette": "white_on_green"
                    }
                  ]
                }
              ],
              "autoscale": true,
              "precision": 1,
              "timeseries_background": {
                "type": "area"
              }
            },
            "layout": {
              "x": 8,
              "y": 0,
              "width": 4,
              "height": 2
            }
          },
          {
            "id": 86266938491004,
            "definition": {
              "title": "GPU Daily Cost vs Utilization",
              "title_size": "16",
              "title_align": "left",
              "show_legend": true,
              "legend_layout": "auto",
              "legend_columns": [
                "avg",
                "value",
                "sum"
              ],
              "time": {
                "hide_incomplete_cost_data": true
              },
              "type": "timeseries",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "cloud_cost",
                      "name": "query1",
                      "query": "sum:gcp.cost.amortized.shared.resources.allocated{NOT credits_type:PROMOTION AND NOT google_usage_type:*PD* AND NOT google_usage_type:*Transfer* AND NOT google_usage_type:*Vertex* AND (google_usage_type:*GPU* OR compute.googleapis.com/machine_spec:*a2* OR compute.googleapis.com/machine_spec:*g2* OR compute.googleapis.com/machine_spec:*a3*) AND $zone AND $team}.rollup(sum, daily)"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "query1",
                      "alias": "Daily GPU Cost"
                    }
                  ],
                  "response_format": "timeseries",
                  "on_right_yaxis": false,
                  "style": {
                    "palette": "dog_classic",
                    "line_type": "solid",
                    "line_width": "normal"
                  },
                  "display_type": "bars"
                },
                {
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "query2",
                      "query": "avg:gpu.sm_active{cloud_provider:gcp AND $zone AND $team}"
                    },
                    {
                      "data_source": "metrics",
                      "name": "query3",
                      "query": "avg:gpu.gr_engine_active{cloud_provider:gcp AND $zone AND $team}"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "query2",
                      "alias": "GPU Utilization %"
                    },
                    {
                      "formula": "100 - query3",
                      "alias": "GPU Idle %"
                    }
                  ],
                  "response_format": "timeseries",
                  "on_right_yaxis": true,
                  "style": {
                    "palette": "dog_classic",
                    "line_type": "solid",
                    "line_width": "thick"
                  },
                  "display_type": "line"
                }
              ],
              "right_yaxis": {
                "min": "0",
                "max": "100"
              }
            },
