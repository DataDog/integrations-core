{
  "title": "GCP GPU Cost Overview",
  "description": "Use this dashboard to investigate GCP GPU compute spend, understand where spend is concentrated across machine specs and commitment models, and correlate costs with GPU hardware utilization.",
  "widgets": [
    {
      "id": 451149432202284,
      "definition": {
        "type": "note",
        "content": "Cost data reflects total cloud spend. Utilization values reflect only hosts reporting the Datadog Agent \u2014 [set up GPU Monitoring](https://docs.datadoghq.com/gpu_monitoring/setup/) to populate utilization widgets.",
        "background_color": "green",
        "font_size": "14",
        "text_align": "center",
        "vertical_align": "center",
        "show_tick": true,
        "tick_pos": "50%",
        "tick_edge": "bottom",
        "has_padding": false
      },
      "layout": {
        "x": 0,
        "y": 0,
        "width": 12,
        "height": 1
      }
    },
    {
      "id": 86266938490600,
      "definition": {
        "title": "GPU Spend by SKU (past 30 days)",
        "time": {
          "type": "live",
          "unit": "month",
          "value": 1,
          "hide_incomplete_cost_data": true
        },
        "comparison_time": {
          "hide_incomplete_cost_data": true
        },
        "type": "cloud_cost_summary",
        "requests": [
          {
            "response_format": "timeseries",
            "queries": [
              {
                "data_source": "cloud_cost",
                "name": "query1",
                "query": "sum:gcp.cost.amortized.shared.resources.allocated{NOT credits_type:PROMOTION AND NOT google_usage_type:*PD* AND NOT google_usage_type:*Transfer* AND NOT google_usage_type:*Vertex* AND (google_usage_type:*GPU* OR compute.googleapis.com/machine_spec:*a2* OR compute.googleapis.com/machine_spec:*g2* OR compute.googleapis.com/machine_spec:*a3*) AND $zone AND $team} by {sku_description}.rollup(sum, daily)"
              }
            ],
            "formulas": [
              {
                "formula": "query1"
              }
            ]
          }
        ],
        "graph_options": [
          {
            "type": "query_value",
            "view": "total"
          },
          {
            "type": "query_value",
            "view": "change"
          },
          {
            "type": "timeseries",
            "display_type": "bars"
          },
          {
            "type": "cloud_cost_table",
            "view": "summary",
            "sort": {
              "type": "formula",
              "index": 0,
              "order": "desc"
            }
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 1,
        "width": 12,
        "height": 6
      }
    },
    {
      "id": 451149432202282,
      "definition": {
        "title": "GPU Spend",
        "title_size": "16",
        "title_align": "left",
        "time": {
          "hide_incomplete_cost_data": true
        },
        "type": "query_value",
        "requests": [
          {
            "formulas": [
              {
                "formula": "query1",
                "number_format": {
                  "unit": {
                    "type": "canonical_unit",
                    "unit_name": "dollar"
                  }
                }
              }
            ],
            "queries": [
              {
                "aggregator": "sum",
                "data_source": "cloud_cost",
                "name": "query1",
                "query": "sum:gcp.cost.amortized.shared.resources.allocated{NOT credits_type:PROMOTION AND NOT google_usage_type:*PD* AND NOT google_usage_type:*Transfer* AND NOT google_usage_type:*Vertex* AND (google_usage_type:*GPU* OR compute.googleapis.com/machine_spec:*a2* OR compute.googleapis.com/machine_spec:*g2* OR compute.googleapis.com/machine_spec:*a3*) AND $zone AND $team}"
              }
            ],
            "response_format": "scalar"
          }
        ],
        "autoscale": true,
        "precision": 2,
        "timeseries_background": {
          "type": "area"
        }
      },
      "layout": {
        "x": 0,
        "y": 7,
        "width": 3,
        "height": 2
      }
    },
    {
      "id": 451149432202283,
      "definition": {
        "title": "Spend on Idle GPUs (past 30 days)",
        "title_size": "16",
        "title_align": "left",
        "time": {
          "type": "live",
          "unit": "month",
          "value": 1,
          "hide_incomplete_cost_data": true
        },
        "type": "query_value",
        "requests": [
          {
            "formulas": [
              {
                "formula": "query1 * (100 - query2) / 100",
                "number_format": {
                  "unit": {
                    "type": "canonical_unit",
                    "unit_name": "dollar"
                  }
                }
              }
            ],
            "queries": [
              {
                "aggregator": "sum",
                "data_source": "cloud_cost",
                "name": "query1",
                "query": "sum:gcp.cost.amortized.shared.resources.allocated{NOT credits_type:PROMOTION AND NOT google_usage_type:*PD* AND NOT google_usage_type:*Transfer* AND NOT google_usage_type:*Vertex* AND (google_usage_type:*GPU* OR compute.googleapis.com/machine_spec:*a2* OR compute.googleapis.com/machine_spec:*g2* OR compute.googleapis.com/machine_spec:*a3*) AND $zone AND $team}"
              },
              {
                "aggregator": "avg",
                "data_source": "metrics",
                "name": "query2",
                "query": "avg:gpu.gr_engine_active{cloud_provider:gcp AND $zone AND $team}"
              }
            ],
            "response_format": "scalar"
          }
        ],
        "autoscale": true,
        "precision": 2,
        "timeseries_background": {
          "type": "area"
        }
      },
      "layout": {
        "x": 3,
        "y": 7,
        "width": 3,
        "height": 2
      }
    },
    {
      "id": 6319145973082921,
      "definition": {
        "type": "note",
        "content": "GCP GPU spend covers **GPU usage types** and GPU-accelerated machine specs (**a2, g2, a3** families). Promotional credits are excluded. Coverage is shown by consumption model (Default = On-Demand, CUD = Committed Use Discount).",
        "background_color": "green",
        "font_size": "14",
        "text_align": "left",
        "vertical_align": "center",
        "show_tick": false,
        "has_padding": true
      },
      "layout": {
        "x": 6,
        "y": 7,
        "width": 6,
        "height": 2
      }
    },
    {
      "id": 1757585486409348,
      "definition": {
        "title": "GPU Coverage by Cost Type",
        "title_size": "16",
        "title_align": "left",
        "show_legend": true,
        "legend_layout": "auto",
        "legend_columns": [
          "avg",
          "min",
          "max",
          "value",
          "sum"
        ],
        "time": {
          "hide_incomplete_cost_data": true
        },
        "type": "timeseries",
        "requests": [
          {
            "formulas": [
              {
                "alias": "On-Demand",
                "formula": "query1"
              },
              {
                "alias": "Committed",
                "formula": "query2"
              }
            ],
            "queries": [
              {
                "data_source": "cloud_cost",
                "name": "query1",
                "query": "sum:gcp.cost.amortized.shared.resources.allocated{NOT credits_type:PROMOTION AND NOT google_usage_type:*PD* AND NOT google_usage_type:*Transfer* AND NOT google_usage_type:*Vertex* AND (google_usage_type:*GPU* OR compute.googleapis.com/machine_spec:*g2* OR compute.googleapis.com/machine_spec:*a2* OR compute.googleapis.com/machine_spec:*a3*) AND NOT google_usage_type:*Commit* AND $zone AND $team}.rollup(sum, daily)"
              },
              {
                "data_source": "cloud_cost",
                "name": "query2",
                "query": "sum:gcp.cost.amortized.shared.resources.allocated{NOT credits_type:PROMOTION AND NOT google_usage_type:*PD* AND NOT google_usage_type:*Transfer* AND NOT google_usage_type:*Vertex* AND (google_usage_type:*GPU* OR compute.googleapis.com/machine_spec:*g2* OR compute.googleapis.com/machine_spec:*a2* OR compute.googleapis.com/machine_spec:*a3*) AND google_usage_type:*Commit* AND $zone AND $team}.rollup(sum, daily)"
              }
            ],
            "response_format": "timeseries",
            "style": {
              "color_order": "monotonic",
              "order_by": "values",
              "palette": "dog_classic",
              "line_type": "solid",
              "line_width": "normal"
            },
            "display_type": "bars"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 9,
        "width": 6,
        "height": 3
      }
    },
    {
      "id": 8018270029565740,
      "definition": {
        "title": "On-Demand % of GPU Spend",
        "title_size": "16",
        "title_align": "left",
        "show_legend": true,
        "legend_layout": "auto",
        "legend_columns": [
          "avg",
          "min",
          "max",
          "value",
          "sum"
        ],
        "time": {
          "hide_incomplete_cost_data": true
        },
        "type": "timeseries",
        "requests": [
          {
            "formulas": [
              {
                "alias": "On-Demand %",
                "formula": "100 * (query2 / query1)",
                "style": {
                  "palette": "blue",
                  "palette_index": 4
                }
              }
            ],
            "queries": [
              {
                "data_source": "cloud_cost",
                "name": "query2",
                "query": "sum:gcp.cost.amortized.shared.resources.allocated{NOT credits_type:PROMOTION AND NOT google_usage_type:*PD* AND NOT google_usage_type:*Transfer* AND NOT google_usage_type:*Vertex* AND (google_usage_type:*GPU* OR compute.googleapis.com/machine_spec:*g2* OR compute.googleapis.com/machine_spec:*a2* OR compute.googleapis.com/machine_spec:*a3*) AND NOT google_usage_type:*Commit* AND $zone AND $team}.rollup(sum, daily)"
              },
              {
                "data_source": "cloud_cost",
                "name": "query1",
                "query": "sum:gcp.cost.amortized.shared.resources.allocated{NOT credits_type:PROMOTION AND NOT google_usage_type:*PD* AND NOT google_usage_type:*Transfer* AND NOT google_usage_type:*Vertex* AND (google_usage_type:*GPU* OR compute.googleapis.com/machine_spec:*g2* OR compute.googleapis.com/machine_spec:*a2* OR compute.googleapis.com/machine_spec:*a3*) AND $zone AND $team}.rollup(sum, daily)"
              }
            ],
            "response_format": "timeseries",
            "style": {
              "color_order": "monotonic",
              "order_by": "values",
              "palette": "dog_classic",
              "line_type": "solid",
              "line_width": "normal"
            },
            "display_type": "line"
          }
        ]
      },
      "layout": {
        "x": 6,
        "y": 9,
        "width": 6,
        "height": 3
      }
    },
    {
      "id": 23055904670847,
      "definition": {
        "title": "GPU Spend by Machine Type",
        "title_size": "16",
        "title_align": "left",
        "time": {
          "hide_incomplete_cost_data": true
        },
        "type": "query_table",
        "requests": [
          {
            "queries": [
              {
                "aggregator": "sum",
                "data_source": "cloud_cost",
                "name": "query1",
                "query": "sum:gcp.cost.amortized.shared.resources.allocated{NOT credits_type:PROMOTION AND NOT google_usage_type:*PD* AND NOT google_usage_type:*Transfer* AND NOT google_usage_type:*Vertex* AND (google_usage_type:*GPU* OR compute.googleapis.com/machine_spec:*a2* OR compute.googleapis.com/machine_spec:*g2* OR compute.googleapis.com/machine_spec:*a3*) AND $zone AND $team} by {compute.googleapis.com/machine_spec}.rollup(sum, daily)"
              },
              {
                "aggregator": "sum",
                "data_source": "cloud_cost",
                "name": "query2",
                "query": "sum:gcp.cost.amortized.shared.resources.allocated{NOT credits_type:PROMOTION AND NOT google_usage_type:*PD* AND NOT google_usage_type:*Transfer* AND NOT google_usage_type:*Vertex* AND (google_usage_type:*GPU* OR compute.googleapis.com/machine_spec:*a2* OR compute.googleapis.com/machine_spec:*g2* OR compute.googleapis.com/machine_spec:*a3*) AND $zone AND $team}"
              }
            ],
            "response_format": "scalar",
            "sort": {
              "count": 500,
              "order_by": [
                {
                  "index": 0,
                  "order": "desc",
                  "type": "formula"
