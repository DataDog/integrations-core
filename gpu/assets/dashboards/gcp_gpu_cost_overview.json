{
  "title": "GCP GPU Cost Overview",
  "description": "Monitor GCP GPU compute spend including machine spec breakdowns, commitment coverage, and cost trends.",
  "widgets": [
    {
      "id": 86266938490582,
      "definition": {
        "title": "GCP GPU Spend",
        "background_color": "vivid_green",
        "show_title": true,
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "id": 451149432202282,
            "definition": {
              "title": "GCP GPU Spend",
              "title_size": "16",
              "title_align": "left",
              "time": {
                "hide_incomplete_cost_data": true
              },
              "type": "query_value",
              "requests": [
                {
                  "formulas": [
                    {
                      "formula": "query1",
                      "number_format": {
                        "unit": {
                          "type": "canonical_unit",
                          "unit_name": "dollar"
                        }
                      }
                    }
                  ],
                  "queries": [
                    {
                      "aggregator": "sum",
                      "data_source": "cloud_cost",
                      "name": "query1",
                      "query": "sum:gcp.cost.amortized.shared.resources.allocated{NOT credits_type:PROMOTION AND NOT google_usage_type:*PD* AND NOT google_usage_type:*Transfer* AND (google_usage_type:*GPU* OR compute.googleapis.com/machine_spec:*a2* OR compute.googleapis.com/machine_spec:*g2* OR compute.googleapis.com/machine_spec:*a3*) AND $availability-zone AND $team AND $kube_cluster_name}"
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "autoscale": true,
              "precision": 2,
              "timeseries_background": {
                "type": "area"
              }
            },
            "layout": {
              "x": 0,
              "y": 0,
              "width": 3,
              "height": 2
            }
          },
          {
            "id": 6319145973082921,
            "definition": {
              "type": "note",
              "content": "GCP GPU spend covers **GPU usage types** and GPU-accelerated machine specs (**a2, g2, a3** families). Promotional credits are excluded. Coverage is shown by consumption model (Default = On-Demand, CUD = Committed Use Discount).",
              "background_color": "green",
              "font_size": "14",
              "text_align": "left",
              "vertical_align": "center",
              "show_tick": false,
              "has_padding": true
            },
            "layout": {
