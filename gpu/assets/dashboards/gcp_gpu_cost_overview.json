                "number_format": {
                  "unit": {
                    "type": "canonical_unit",
                    "unit_name": "dollar"
                  }
                }
              },
              {
                "alias": "% of Total Spend",
                "cell_display_mode": "bar",
                "formula": "query1 / query2 * 100",
                "number_format": {
                  "unit": {
                    "type": "canonical_unit",
                    "unit_name": "percent"
                  }
                }
              }
            ]
          }
        ],
        "has_search_bar": "auto"
      },
      "layout": {
        "x": 0,
        "y": 12,
        "width": 6,
        "height": 4
