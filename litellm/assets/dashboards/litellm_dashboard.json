      "id": 8000,
      "definition": {
        "title": "Other Useful Metrics",
        "background_color": "vivid_blue",
        "show_title": true,
        "type": "group",
        "layout_type": "ordered",
        "widgets": [
          {
            "id": 8001,
            "definition": {
              "type": "query_value",
              "title": "Total Spend",
              "requests": [
                {
                  "formulas": [{ "formula": "query1" }],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "query1",
                      "query": "sum:litellm.spend.metric.count{}",
                      "aggregator": "sum"
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "autoscale": true,
              "precision": 2
            },
            "layout": { "x": 0, "y": 0, "width": 2, "height": 1 }
          },
          {
            "id": 8002,
            "definition": {
              "type": "query_value",
              "title": "Process Uptime (seconds)",
              "requests": [
                {
                  "formulas": [{ "formula": "query1" }],
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "query1",
                      "query": "avg:litellm.process.uptime.seconds{}",
                      "aggregator": "avg"
                    }
                  ],
                  "response_format": "scalar"
                }
              ],
              "autoscale": true,
              "precision": 0
            },
            "layout": { "x": 2, "y": 0, "width": 2, "height": 1 }
          }
        ]
      },
      "layout": { "x": 0, "y": 19, "width": 12, "height": 1 }
