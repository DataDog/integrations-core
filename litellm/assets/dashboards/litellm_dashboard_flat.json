    {
      "definition": {
        "type": "query_value",
        "title": "Deployment Failures",
        "requests": [
          {
            "formulas": [
              { "formula": "query1" }
            ],
            "queries": [
              {
                "data_source": "metrics",
                "name": "query1",
                "query": "sum:litellm.deployment.failure_responses.count{}",
                "aggregator": "sum"
              }
            ],
            "response_format": "scalar"
          }
        ],
        "autoscale": true,
        "precision": 0
      }
    },
    {
      "definition": {
